{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "User feedback or comment from the message board",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The content of the message" },
        "authorEmail": { "type": "string", "format": "email", "description": "Email of the user who sent the message" },
        "authorId": { "type": "string", "description": "UID of the user who sent the message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp of creation" }
      },
      "required": ["text", "authorEmail", "authorId", "createdAt"]
    },
    "Counter": {
      "title": "Counter",
      "description": "Global counters for the application",
      "type": "object",
      "properties": {
        "likes": { "type": "integer", "description": "Number of likes" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Server timestamp of last increment" }
      },
      "required": ["likes", "lastUpdated"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User suggestions and feedback",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The feedback text content" },
        "contact": { "type": "string", "description": "Optional contact info (email/phone)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp of creation" }
      },
      "required": ["content", "createdAt"]
    }
  },
  "firestore": {
    "messages": {
      "schema": "Message",
      "description": "Collection of all user messages"
    },
    "counters": {
      "schema": "Counter",
      "description": "Collection for global counters like likes"
    },
    "feedbacks": {
      "schema": "Feedback",
      "description": "Collection for user suggestions and feedback"
    }
  }
}
