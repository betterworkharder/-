rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /counters/likes {
      allow read: if true;
      allow create: if isValidCounter(request.resource.data) && 
                    (request.resource.data.likes == 0 || request.resource.data.likes == 1);
      allow update: if isValidCounter(request.resource.data) && 
                    request.resource.data.likes == (resource.data.likes + 1) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'lastUpdated']);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'xianyinjiang9@gmail.com' ||
        request.auth.token.email_verified == true && request.auth.token.email == 'xianyinjiang9@gmail.com'
      );
    }

    function isValidMessage(data) {
      return data.text is string && data.text.size() <= 1000 &&
             data.authorEmail is string &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidCounter(data) {
      return data.likes is int && data.likes >= 0 &&
             data.lastUpdated == request.time;
    }

    function isValidFeedback(data) {
      return data.content is string && data.content.size() <= 2000 &&
             (data.contact == null || (data.contact is string && data.contact.size() <= 200)) &&
             data.createdAt == request.time;
    }

    match /messages/{messageId} {
      allow create: if isSignedIn() && isValidMessage(request.resource.data);
      allow get: if isSignedIn() && (isOwner(resource.data.authorId) || isAdmin());
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }

    match /feedbacks/{feedbackId} {
      allow create: if isValidFeedback(request.resource.data);
      allow get, list, delete: if isAdmin();
    }

  }
}
