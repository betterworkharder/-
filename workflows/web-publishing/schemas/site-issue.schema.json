{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fengxing generated site issue DTO",
  "type": "object",
  "required": ["schema_version", "issue_id", "issue_date", "display_date", "title", "categories", "provenance"],
  "properties": {
    "schema_version": {"const": 1},
    "issue_id": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "issue_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "display_date": {"type": "string"},
    "title": {"type": "string"},
    "categories": {
      "type": "array",
      "minItems": 4,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "title", "icon", "description", "news"]
      }
    },
    "provenance": {
      "type": "object",
      "required": ["type", "source_file", "source_hash", "content_hash"]
    }
  }
}
